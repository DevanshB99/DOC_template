<?xml version="1.0" encoding="UTF-8" ?>
<!--
  FastDDS profile — 10MB UDP socket buffers for reliable image topic transport.
  Active when RMW_IMPLEMENTATION=rmw_fastrtps_cpp (the default).
  The micro-ROS agent inherits FASTRTPS_DEFAULT_PROFILES_FILE and uses this
  same profile, so the agent and the ROS stack share one transport configuration.

  Both machines on a cross-host ROS graph need this profile (and the kernel
  sysctl limits set by install.sh) for reliable large-message delivery.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <transport_descriptors>
        <transport_descriptor>
            <transport_id>udpv4_tuned</transport_id>
            <type>UDPv4</type>
            <sendBufferSize>10485760</sendBufferSize>
            <receiveBufferSize>10485760</receiveBufferSize>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="participant_default" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>udpv4_tuned</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>
        </rtps>
    </participant>

</profiles>
