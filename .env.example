# Copy to .env and customize, or let install.sh populate it automatically.
# Profiles: linux | linux-gpu | jetson | rpi | mac | windows

# Container / ROS
CONTAINER_NAME=my_project
ROS_DOMAIN_ID=0
USERNAME=doc_user
PLATFORM=auto
COMPOSE_PROFILES=linux

# DDS middleware. FastDDS is required for micro-ROS agent compatibility.
# Switch to rmw_cyclonedds_cpp only if you are NOT using micro-ROS.
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Ollama (optional)
# linux/jetson/rpi: Ollama sidecar starts automatically with the profile.
# mac: run Ollama natively — brew install ollama && brew services start ollama
#      OLLAMA_HOST defaults to host.docker.internal:11434, no change needed.
# LAN GPU server: set OLLAMA_HOST to the server's LAN IP.
# OLLAMA_HOST=http://127.0.0.1:11434
